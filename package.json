{
  "name": "ryan-chung-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Ryan Chung freelance developer portfolio. Static prerendered client + Express contact server.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "preview": "npm run preview --workspace client",
    "start:server": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
