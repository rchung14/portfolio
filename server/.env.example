# Port the contact server listens on.
PORT=3001

# Comma-separated list of allowed browser origins (the client site).
# Leave empty to allow all origins (fine for local dev).
# Example (Vite dev): http://localhost:5173
# Example (prod):     https://ryanchung.dev
CLIENT_ORIGIN=http://localhost:5173

# Where contact submissions are delivered, and the From header used to send.
CONTACT_TO=ryanchung14@gmail.com
CONTACT_FROM="Portfolio Contact <onboarding@resend.dev>"

# Resend API key. If left empty, the server LOGS emails instead of sending
# them, which is handy for local development.
#
# 1. Create a key at https://resend.com/api-keys
# 2. For real delivery, verify your sending domain in Resend and set
#    CONTACT_FROM to an address on it (e.g. Portfolio Contact <hello@ryanchung.dev>).
#    Until a domain is verified, Resend's onboarding@resend.dev sender can only
#    deliver to the email on your Resend account.
RESEND_API_KEY=
